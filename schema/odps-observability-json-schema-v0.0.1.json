{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://bitol-io.github.io/open-data-product-observability-standard/schema/odps-observability-json-schema-v0.0.1.json",
    "title": "DataProductObservability",
    "description": "Observability specification compatible with [Bitol ODPS data product specification](https://bitol-io.github.io/open-data-product-standard)",
    "type": "object",
    "required": [
        "schemaVersion",
        "kind",
        "productId",
        "asOf",
        "period",
        "status"
    ],
    "properties": {
        "schemaVersion": {
            "type": "string",
            "description": "Semantic version of this schema. Consumers should use this for compatibility checks.",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
            "examples": [
                "0.0.1"
            ]
        },
        "kind": {
            "type": "string",
            "default": "DataProductObservability",
            "description": "The kind of file this is. Valid value is `DataProductObservability`.",
            "enum": [
                "DataProductObservability"
            ]
        },
        "productId": {
            "type": "string",
            "description": "UUID of the data product as declared in the ODPS",
            "examples": [
                "fbe8d147-28db-4f1d-bedf-a3fe9f458427"
            ]
        },
        "asOf": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 UTC timestamp at which these metrics were collected."
        },
        "period": {
            "type": "string",
            "description": "ISO 8601 duration representing the observation window for rate-based metrics.",
            "pattern": "^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+W)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$",
            "examples": [
                "P1D",
                "P7W",
                "P1M"
            ]
        },
        "status": {
            "type": "string",
            "description": "Composite any-case health status derived across all dimensions and output ports.",
            "enum": [
                "healthy",
                "degraded",
                "critical",
                "unknown"
            ]
        },
        "physical": {
            "type": "object",
            "description": "Physical-space metrics: compute, pipeline runtime, and storage.",
            "properties": {
                "pipeline": {
                    "type": "object",
                    "description": "Most recent pipeline execution for this data product.",
                    "required": [
                        "status"
                    ],
                    "properties": {
                        "lastRunAt": {
                            "type": [
                                "string",
                                "null"
                            ],
                            "format": "date-time",
                            "description": "UTC timestamp when the last pipeline run started."
                        },
                        "durationSeconds": {
                            "type": [
                                "number",
                                "null"
                            ],
                            "minimum": 0,
                            "description": "Wall-clock duration of the last run in seconds. Null if the run failed before completion."
                        },
                        "status": {
                            "type": "string",
                            "enum": [
                                "success",
                                "failed",
                                "running",
                                "skipped",
                                "unknown"
                            ],
                            "description": "Terminal or current status of the last pipeline execution."
                        },
                        "errorMessage": {
                            "type": [
                                "string",
                                "null"
                            ],
                            "description": "Human-readable error message if status=failed.",
                            "maxLength": 1024
                        },
                        "recordsProcessed": {
                            "type": [
                                "integer",
                                "null"
                            ],
                            "minimum": 0,
                            "description": "Number of records processed end-to-end by the pipeline in the last run — i.e. records that completed the full source-to-output transformation. Distinct from dynamic.volume.rowCount, which reflects the resulting stored state of the output port. Null if the run failed before completion or if the pipeline does not emit this metric."
                        },
                        "meanTimeBetweenFailuresDays": {
                            "type": [
                                "number",
                                "null"
                            ],
                            "minimum": 0,
                            "description": "MTBF is the average time between repairable failures of a pipeline. Computed from physical.pipeline events: time between status=failed and next status=success."
                        },
                        "meanTimeToRecoveryMinutes": {
                            "type": [
                                "number",
                                "null"
                            ],
                            "minimum": 0,
                            "description": "MTTR Mean time to recovery is the average time it takes to recover from an incident. Computed from physical.pipeline events: time between status=failed and next status=success."
                        }
                    }
                }
            }
        }
    },
    "additionalProperties": false,
    "examples": [
        {
            "schemaVersion": "0.0.1",
            "kind": "DataProductObservability",
            "productId": "fbe8d147-28db-4f1d-bedf-a3fe9f458427",
            "asOf": "2026-03-14T09:00:00Z",
            "period": "P1D",
            "status": "healthy",
            "physical": {
                "pipeline": {
                    "lastRunAt": "2026-03-13T08:45:00Z",
                    "durationSeconds": 1200,
                    "status": "success",
                    "recordsProcessed": 1000000,
                    "computeCreditsUsed": 100,
                    "meanTimeBetweenFailuresDays": 12,
                    "meanTimeToRecoveryMinutes": 45
                }
            }
        },
        {
            "schemaVersion": "0.0.1",
            "productId": "fbe8d147-28db-4f1d-bedf-a3fe9f458427",
            "asOf": "2026-03-14T09:00:00Z",
            "period": "P1D",
            "status": "critical",
            "physical": {
                "pipeline": {
                    "lastRunAt": "2026-03-13T08:45:00Z",
                    "durationSeconds": 1200,
                    "status": "failed",
                    "errorMessage": "Source system unavailable: connection timeout after 30s",
                    "meanTimeBetweenFailuresDays": 12,
                    "meanTimeToRecoveryMinutes": 45
                }
            }
        }
    ]
}